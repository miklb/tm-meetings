{# ── Latest Week (featured) ── #}
{% set latestDate = meetings.publicDates[0] %}
{% set latestMeetings = meetings.publicByDate[latestDate] %}

{% if latestDate %}
    <section class="latest-week" aria-label="Latest meetings">
        <h2 class="section-heading">Latest</h2>
        <div class="featured-grid">
            {% for meeting in latestMeetings %}
                <article class="featured-card">
                    <a href="/meetings/{{ meeting.id }}/" class="featured-link">
                        <div class="featured-thumb">
                            {% if meeting.video_id %}
                                <img src="{{ meeting.video_id | ytThumb }}" alt="" loading="lazy" width="320" height="180">
                            {% else %}
                                <img src="/img/meeting-placeholder.jpg" alt="" loading="lazy" width="320" height="180">
                            {% endif %}
                        </div>
                        <div class="featured-body">
                            <span class="meeting-type-label">{{ meeting.meeting_type | meetingTypeLabel }}</span>
                            <h3 class="featured-title">{{ meeting.title }}</h3>
                            <time class="featured-date" datetime="{{ meeting.date }}">{{ meeting.date | readableDate }}</time>
                            {% if meeting.item_count > 0 %}
                                <span class="featured-meta">{{ meeting.item_count }}
                                    agenda item{{ "s" if meeting.item_count != 1 }}</span>
                            {% endif %}
                        </div>
                    </a>
                </article>
            {% endfor %}
        </div>
    </section>
{% endif %}

{# ── Previous Meetings ── #}
{% if meetings.publicDates.length > 1 %}
    <section class="previous-meetings" aria-label="Previous meetings">
        <h2 class="section-heading">Previous Meetings</h2>

        <div class="meetings-archive" id="meetings-archive">
            {% for date in meetings.publicDates %}
                {% if loop.index0 > 0 %}
                    <div class="date-group{% if loop.index0 > 10 %} archive-hidden{% endif %}">
                        <h3 class="date-heading">
                            <time datetime="{{ date }}">{{ date | readableDate }}</time>
                        </h3>
                        <ul class="meeting-list" role="list">
                            {% for meeting in meetings.publicByDate[date] %}
                                <li class="meeting-row">
                                    <a href="/meetings/{{ meeting.id }}/" class="meeting-row-link">
                                        {% if meeting.video_id %}
                                            <img class="meeting-row-thumb" src="{{ meeting.video_id | ytThumb }}" alt="" loading="lazy" width="120" height="68">
                                        {% else %}
                                            <img class="meeting-row-thumb" src="/img/meeting-placeholder.jpg" alt="" loading="lazy" width="120" height="68">
                                        {% endif %}
                                        <div class="meeting-row-body">
                                            <span class="meeting-type-label">{{ meeting.meeting_type | meetingTypeLabel }}</span>
                                            <span class="meeting-row-title">{{ meeting.title }}</span>
                                            {% if meeting.item_count > 0 %}
                                                <span class="meeting-row-meta">{{ meeting.item_count }}
                                                    item{{ "s" if meeting.item_count != 1 }}</span>
                                            {% endif %}
                                        </div>
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endif %}
            {% endfor %}
        </div>

        {% if meetings.publicDates.length > 11 %}
            <button class="show-more-btn" id="show-more-btn" type="button">
                Show More Meetings
            </button>
            <script>
                (function () {
                    var btn = document.getElementById('show-more-btn');
                    var archive = document.getElementById('meetings-archive');
                    btn.addEventListener('click', function () {
                        var hidden = archive.querySelectorAll('.archive-hidden');
                        for (var i = 0; i < hidden.length; i++) {
                            hidden[i]
                                .classList
                                .remove('archive-hidden');
                        }
                        btn.remove();
                    });
                })();
            </script>
        {% endif %}
    </section>
{% endif %}