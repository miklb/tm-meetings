<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title or "Tampa City Council Meetings" }}</title>
    <link rel="stylesheet" href="/css/style.css">
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="site-header">
      <nav aria-label="Primary">
        <a href="/" class="site-title">Tampa Meetings</a>
        <a href="/about/" class="nav-link">About</a>
      </nav>
    </header>

    <main id="main-content">
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <p>Data sourced from the
        <a href="https://tampagov.hylandcloud.com/221agendaonline/">Tampa City Clerk — Hyland OnBase</a>. This is an unofficial resource.</p>
    </footer>

    {# Load video + search scripts only on meeting pages with media #}
    {% if meeting and(meeting.has_video or meeting.has_transcript) %}
      <script src="https://www.youtube.com/iframe_api"></script>
      <script src="/js/video-player.js" defer="defer"></script>
      <script src="/js/search.js" defer="defer"></script>
      <script src="/js/agenda-drawer.js" defer="defer"></script>
    {% endif %}
  </body>
</html>