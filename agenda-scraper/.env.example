MAPBOX_API_TOKEN=your_mapbox_api_token_here

# Cloudflare R2 (recommended) for document mirroring
# Get credentials from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your_r2_access_key
S3_SECRET_ACCESS_KEY=your_r2_secret_key
S3_BUCKET=agenda-documents

# Public URL configuration:
# Option 1: R2 dev URL (bucket name is in the path)
S3_PUBLIC_URL=https://pub-XXXX.r2.dev

# Option 2: Custom domain (bucket is implicit, domain points to bucket)
# S3_PUBLIC_URL=https://docs.yoursite.com
# S3_CUSTOM_DOMAIN=true
